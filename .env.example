# OpenAI (optional — enables LLM answer generation on the API server)
OPENAI_API_KEY=

# API security (required in production)
API_KEY=change-me-to-a-strong-secret

# API URL for Streamlit and other clients
API_URL=http://localhost:8000

# Rate limiting (slowapi format)
RATE_LIMIT=30/minute

# Retrieval tuning
RETRIEVE_K=15
FINAL_K=3
MAX_FINAL_K=10
MIN_CHUNK_SIMILARITY=0.40
MIN_SIMILARITY_THRESHOLD=0.35
LOW_CONFIDENCE_THRESHOLD=0.30
RERANK_ENABLED=true

# Generation
OPENAI_MODEL=gpt-3.5-turbo
NOT_FOUND_ANSWER=Not found
MAX_QUESTION_LENGTH=2000

# Debug (disable in production)
DEBUG_MODE=false
