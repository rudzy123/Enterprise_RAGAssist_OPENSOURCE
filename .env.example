# =============================================================================
# Enterprise RAG Assistant — environment configuration
# Copy to .env and customize:  cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED in production)
# -----------------------------------------------------------------------------
API_KEY=change-me-to-a-strong-secret
RATE_LIMIT=30/minute
DEBUG_MODE=false

# -----------------------------------------------------------------------------
# LLM provider selection
# Priority:
#   1. LLM_PROVIDER=ollama → ollama.chat() with llama3.2
#   2. Else if OPENAI_API_KEY is set → OpenAI
#   3. Else → retrieval-only
# If Ollama is not running → warning + retrieval-only fallback
# Values: ollama | retrieval_only | openai | (empty)
# -----------------------------------------------------------------------------
LLM_PROVIDER=ollama

# -----------------------------------------------------------------------------
# Ollama (priority 1 — preferred)
# Install: https://ollama.com
#   ollama pull llama3.2
# OLLAMA_BASE_URL is accepted as an alias for OLLAMA_HOST
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TEMPERATURE=0.0

# -----------------------------------------------------------------------------
# OpenAI (priority 3 — opt-in only)
# Not used unless LLM_PROVIDER=openai
# -----------------------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-3.5-turbo

# -----------------------------------------------------------------------------
# API / clients
# -----------------------------------------------------------------------------
API_URL=http://localhost:8000
UVICORN_HOST=0.0.0.0
UVICORN_PORT=8000
UVICORN_WORKERS=1

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_FILE=enterprise_rag.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# -----------------------------------------------------------------------------
# Optional Redis cache (query embedding cache)
# Enable with CACHE_ENABLED=true and start Redis (docker compose --profile cache)
# -----------------------------------------------------------------------------
REDIS_URL=
REDIS_PORT=6379
CACHE_ENABLED=false
CACHE_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Retrieval — dense pipeline
# -----------------------------------------------------------------------------
RETRIEVE_K=15
FINAL_K=3
MAX_FINAL_K=10
MAX_CHUNKS_PER_FILE=2
MIN_CHUNK_SIMILARITY=0.40
MIN_SIMILARITY_THRESHOLD=0.35
LOW_CONFIDENCE_THRESHOLD=0.30
RERANK_ENABLED=true
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANK_TOP_N=15
RETRIEVAL_STRUCTURED_LOGS=true

# -----------------------------------------------------------------------------
# Hybrid search (dense + BM25) — default OFF for backward compatibility
# Requires re-ingest: python ingestion/embed_and_store.py
# -----------------------------------------------------------------------------
HYBRID_SEARCH=false
HYBRID_ALPHA=0.7
BM25_RETRIEVE_K=15
RRF_K=60
BM25_MIN_SCORE=0.30
BM25_INDEX_DIR=chroma_db/bm25

# -----------------------------------------------------------------------------
# Ingestion / storage paths
# -----------------------------------------------------------------------------
CHUNK_WORD_LIMIT=250
CHUNK_OVERLAP_WORDS=50
CURATED_DOCS_DIR=data/docs/curated
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
CHROMA_DB_PATH=chroma_db
CHROMA_COLLECTION_NAME=enterprise_docs

# -----------------------------------------------------------------------------
# Generation
# -----------------------------------------------------------------------------
NOT_FOUND_ANSWER=Not found
MAX_QUESTION_LENGTH=2000

# -----------------------------------------------------------------------------
# CI eval quality gates (scripts/check_eval_gate.py)
# -----------------------------------------------------------------------------
EVAL_MIN_HIT_AT_K=0.70
EVAL_MIN_MRR=0.65
EVAL_MIN_PRECISION_AT_K=0.35
EVAL_MAX_ABSTENTION_RATE=0.35
EVAL_MIN_PCT_GROUNDED=0.60
